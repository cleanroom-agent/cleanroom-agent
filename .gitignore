# Generated by Cargo
# will have compiled files and executables
target/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More: https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# IDE files
.idea/
*.iml
.vscode/
.vscode/settings.json
*.swp
*.swo

# macOS
.DS_Store

# Temp files
*.tmp
*.temp

# Environment
.env

# SQLite databases (user's local state)
*.db
!migrations/*.sql

# Output directories
output/
sdef-output/

# LSP server binaries (downloaded at runtime)
.lsp-servers/

# Build artifacts
*.o
*.so
*.dylib
*.dll
*.exe

# generated code
generated/
# Downloaded benchmark source codes
tests/fixtures/benchmarks/
